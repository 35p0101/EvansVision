# AI Service - variabili d'ambiente

# Path dove salvare/caricare i modelli addestrati
MODEL_PATH=/app/saved_models

# Origini CORS ammesse (separate da virgola). Usa "*" solo in dev.
# In produzione, limita al solo backend interno.
ALLOWED_ORIGINS=http://localhost:4000,http://backend:4000

# URL del backend (opzionale, per comunicazione inversa)
BACKEND_URL=http://localhost:4000
