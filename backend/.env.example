# Backend - variabili d'ambiente (sviluppo locale fuori docker)
# In docker, queste sono iniettate da docker-compose.yml

# Database PostgreSQL
DATABASE_URL="postgresql://evans:evans_secret@localhost:5432/evansvision"

# JWT
# GENERA con: openssl rand -hex 32   (NON usare questa di default in produzione)
JWT_SECRET="dev_only_change_me_generate_with_openssl_rand_hex_32"
JWT_EXPIRES_IN="7d"

# Servizi
AI_SERVICE_URL="http://localhost:8000"
PORT=4000

# CORS - origini separate da virgola per multipli
CORS_ORIGIN="http://localhost:3000"

# Environment (production attiva validazioni di sicurezza extra)
NODE_ENV="development"

# Rate limiting (opzionale)
# AUTH_RATE_LIMIT_WINDOW_MS=900000      # 15 minuti
# AUTH_RATE_LIMIT_MAX=5                 # 5 tentativi per finestra
