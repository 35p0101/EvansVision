# ====================================================
# EvansVision - Variabili d'ambiente per docker compose
# Copia in `.env` (stessa cartella) e personalizza
# ====================================================

# --- Porte esposte sull'host ---
POSTGRES_PORT=5432
AI_SERVICE_PORT=8000
BACKEND_PORT=4000
FRONTEND_PORT=3000

# --- Database ---
POSTGRES_DB=evansvision
POSTGRES_USER=evans
POSTGRES_PASSWORD=evans_secret
# URL usata dal backend - in docker compose punta al servizio `postgres`
DATABASE_URL=postgresql://evans:evans_secret@postgres:5432/evansvision

# --- Backend ---
NODE_ENV=production
# IMPORTANTISSIMO: generare con `openssl rand -hex 32` e NON committare
JWT_SECRET=dev_only_change_me_generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=7d
AI_SERVICE_URL=http://ai-service:8000
# Origini CORS ammesse (separate da virgola per multipli)
CORS_ORIGIN=http://localhost:3000

# --- AI Service ---
# Origini CORS ammesse per l'AI service (in prod limitarle al solo backend)
AI_ALLOWED_ORIGINS=http://localhost:4000,http://backend:4000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:4000
